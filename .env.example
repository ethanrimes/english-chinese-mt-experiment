# Copy to .env (which is gitignored) and fill in.
# DO NOT commit .env.

# HuggingFace — needed for some gated datasets (none of our defaults are gated, but kept for safety)
HF_TOKEN=

# Weights & Biases — get from https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=english-chinese-mt
WANDB_ENTITY=

# Azure ML
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_ML_WORKSPACE=

# Optional: Azure Blob datastore for checkpoint mirroring
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=ecmt-artifacts

# Cache locations (avoid filling C: on Windows dev boxes)
HF_HOME=./.cache/hf
TRANSFORMERS_CACHE=./.cache/hf/transformers
HF_DATASETS_CACHE=./.cache/hf/datasets
